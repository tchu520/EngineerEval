# =============================================================================
# EngineerEval — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# .NET build output
# -----------------------------------------------------------------------------
bin/
obj/
*.user
*.suo
*.userosscache
*.sln.docstates
.vs/

# -----------------------------------------------------------------------------
# NuGet
# -----------------------------------------------------------------------------
*.nupkg
*.snupkg
packages/
project.lock.json
project.fragment.lock.json
artifacts/

# -----------------------------------------------------------------------------
# Sensitive configuration — real API keys must never be committed.
# Keep appsettings.json (it contains only placeholders).
# Override locally with appsettings.local.json (ignored below).
# -----------------------------------------------------------------------------
appsettings.local.json
appsettings.*.local.json
secrets.json
.env
*.env

# -----------------------------------------------------------------------------
# Runtime output — results and logs are generated on each run
# -----------------------------------------------------------------------------
results/
logs/

# -----------------------------------------------------------------------------
# OS / editor artefacts
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.bak
*~

# -----------------------------------------------------------------------------
# Rider / JetBrains
# -----------------------------------------------------------------------------
.idea/
*.DotSettings.user

# -----------------------------------------------------------------------------
# Visual Studio Code
# -----------------------------------------------------------------------------
.vscode/

# -----------------------------------------------------------------------------
# Internal conversation context (not relevant to public viewers)
# -----------------------------------------------------------------------------
CONVERSATION_CONTEXT.md

